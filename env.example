# Update and cp env.example .env

# MongoDB Configuration
# Local dev (API on host): use localhost
# Docker (API in container): use host.docker.internal to reach MongoDB on the host
MONGODB_URI=mongodb://username:password@localhost:27017/?authSource=admin&directConnection=true
MONGODB_DB=pensive

# LLM Configuration
# OpenAI-compatible API base URL (ChatOpenAI appends /chat/completions).
# LLM_KEY is sent as the api-key header (not Authorization Bearer).
LLM_URI=https://localhost:8080/openai/v1
LLM_MODEL=gpt-5.4
LLM_KEY=YOURKEY

# Embedding Configuration
LLM_EMBEDDING_URI=https://ai.mongodb.com/v1/embeddings
LLM_EMBEDDING_MODEL=voyage-4-lite
LLM_EMBEDDING_KEY=YOURKEY
# Used for creating vector indexes
EMBEDDING_DIMENSIONS=1024

# Optional fallback for curl/local testing without OpenWebUI session headers
# USER_ID=demo-user

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=YOURKEY
LANGSMITH_PROJECT="pensive"